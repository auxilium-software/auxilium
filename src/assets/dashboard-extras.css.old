.case-list-case-container {
    padding: 1rem 0 1rem 0;
    display: block;
    text-decoration: none;
}
.case-list-case-container:hover {
    text-decoration: none;
}
.case-list-case-container > h2 {
    margin: 0 0.3rem 0rem 0;
    vertical-align: text-top;
    display: inline-block;
}
.case-list-case-container > span {
    margin: 0.1rem 0 0.3rem 0;
    vertical-align: text-top;
    display: inline-block;
}
.case-list-case-container > p {
    margin: 0 0 0 0;
    font-size: 0.75rem;
}
.case-list-case-container > h3 {
    margin: 0 0 0.2em 0;
    display: inline-block;
}
