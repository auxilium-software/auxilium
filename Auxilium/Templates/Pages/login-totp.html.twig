{% extends "#{selected_lang}/base.html.twig" %}

{% block title %}Login{% endblock %}

{% block content %}

<div>
    <div class="inner-content">
        <h1>Login</h1>
        <form method="POST">
            <label for="email_address">Email address <span class="asterisk-hidden-text">(required)</span></label>
            <input type="text" name="email_address" placeholder="Email Address" id="email_address" readonly value="{{ form_data.email_address }}" />
            <label for="password">Password <span class="asterisk-hidden-text">(required)</span></label>
            <input type="password" name="password" placeholder="Password" id="password" readonly value="{{ form_data.password }}" />
            <p>Your account is secured using two factor authentication. Please enter the code generated by your authenticator device.</p>
            <label for="totp-code">TOTP Code <span class="asterisk-hidden-text">(required)</span></label>
            <input type="text" name="totp-code" placeholder="### ###" id="totp-code" />
            <p class="error-toast" {% if form_validation.totp %} style="display:none;" {% endif %}>Code provided did not match expected code</p>
            <p class="error-toast" {% if form_validation.totp_used %} style="display:none;" {% endif %}>This code has already been used, try again in 30 seconds</p>
            <input type="submit" value="Login" />
        </form>
        
    </div>
</div>

{% endblock %}
