{
    "name": "auxilium-software/auxilium2",
    "description": "CRM and Case Management Portal",
    "type": "project",
    "license": "Apache-2.0",

    "authors": [
        {
            "name": "Alex Baldwin",
            "email": "alb128@aber.ac.uk",
            "role": "Developer"
        },
        {
            "name": "Cerys Lewis",
            "email": "cerys.lewis@aber.ac.uk",
            "role": "Developer"
        }
    ],
    "support": {
        "email": "info@auxiliumsoftware.co.uk"
    },
    "require": {
        "php": "^8.2",

        "ext-curl": "*",
        "ext-bcmath": "*",
        "ext-gd": "*",
        "ext-openssl": "*",
        "ext-dom": "*",
        "ext-sodium": "*",
        "ext-pdo": "*",
        "ext-mbstring": "*",

        "phpunit/phpunit": "11.4.4",

        "twig/twig": "^3.15.0",

        "endroid/qr-code-bundle": "^4.0",
        "fpdf/fpdf": "^1.83",
        "bigfish/pdf417": "^0.3.0",

        "zbateson/mail-mime-parser": "^3.0",
        "phpmailer/phpmailer": "^6.6",
        "webklex/php-imap": "^3.2",

        "lcobucci/jwt": "^5.4.2",
        "web-token/jwt-core": "^3.4.6",

        "aws/aws-sdk-php": "^3.277",

        "ezyang/htmlpurifier": "^4.14",

        "aura/sqlquery": "2.8.1",

        "darksparrow/deegraph-interactions": "dev-dev",
        "darksparrow/auxilium-schema-builder": "v0.1",

        "geerlingguy/ping": "1.2.1"
    },
    "require-dev": {
        "phpdocumentor/shim": "*"
    },
    "config": {
        "allow-plugins": {
            "endroid/installer": true,
            "phpdocumentor/shim": true
        }
    },
    "autoload": {
        "psr-4": {
            "Auxilium\\": "Auxilium/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
